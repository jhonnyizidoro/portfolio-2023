{
  "name": "nexus-backend",
  "version": "2.0.0",
  "description": "",
  "main": "test-pub.js",
  "packageManager": "npm@11.4.2",
  "jest": {},
  "scripts": {
    "test": "echo \"Error: no test specified in root package.json\" && exit 0",
    "board-test": "jest --testPathPattern=./unit-test/board-sequence-test --config=./unit-test/jest.board.config.js --json --outputFile=board-test-output.json",
    "admin-webapp-test": "jest --testPathPattern=./unit-test/admin-test --config=./unit-test/jest.admin.config.js --json --outputFile=admin-test-output.json",
    "prepare:local": "node -e \"['assets','vizabli-log','node-red'].forEach(d=>{require('fs').mkdirSync(d,{recursive:true});console.log('created',d)})\"",
    "system-healthcheck": "node system-healthcheck.js",
    "release:dev": "release-it patch --ci",
    "release:qa": "release-it --ci --no-increment",
    "release:prod": "release-it --ci --no-increment",
    "lint": "eslint backend-service/ admin-service/ audit-service/ hl7-service/ nursecall-service/ roomStatus-service/ s3cron/ integration-service/",
    "lint:fix": "eslint backend-service/ admin-service/ audit-service/ hl7-service/ nursecall-service/ roomStatus-service/ s3cron/ integration-service/ --fix"
  },
  "repository": {
    "type": "git",
    "url": "ssh://rc/v1/repos/nexus-backend"
  },
  "keywords": [],
  "author": "",
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^29.6.4",
    "@release-it/conventional-changelog": "^8.0.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "husky": "^4.2.5",
    "jest": "^29.7.0",
    "jest-html-reporters": "^3.1.4",
    "lint-staged": "^10.4.0",
    "phin": "^3.7.0",
    "prettier": "^3.7.4",
    "release-it": "^17.10.0",
    "supertest": "^6.3.3",
    "typescript-eslint": "^8.58.1",
    "winston": "^3.9.0"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "commit-msg": "commitlint --edit $HUSKY_GIT_PARAMS"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": "eslint"
  }
