    "react-sortable-tree": "^2.8.0",
    "react-sortable-tree-theme-file-explorer": "^2.0.0",
    "react-svg": "^17.0.0",
    "react-swipeable-views": "^0.14.1",
    "react-swipeable-views-utils": "^0.14.1",
    "react-transition-group": "^4.4.5",
    "react-zoom-pan-pinch": "3.7.0",
    "thenby": "^1.3.4",
    "timesync": "^1.0.11",
    "use-debouncy": "^5.1.7",
    "use-fit-text": "^2.4.0",
    "video.js": "^8.23.7",
    "zustand": "^5.0.12"
