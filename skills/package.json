  "scripts": {
    "start": "vite",
    "build": "vite build",
    "check:new-ui-style-imports": "node .husky/check-new-ui-style-imports.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "stylelint": "stylelint \"src/**/*.{css,scss,sass}\"",
    "stylelint:fix": "stylelint \"src/**/*.{css,scss,sass}\" --fix",
    "lint-staged": "lint-staged",
    "typecheck": "tsc --noEmit",
    "push:prod": "git push origin master:release-1",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "buildnmove": "vite build && cp -r ./build ../nexus-backend/web-server/",
    "storybook": "start-storybook -p 6006 -s public",
    "build-storybook": "build-storybook -s public",
    "prepush": "npm run test && npm run audit",
    "audit": "node node_modules/better-npm-audit audit",
    "release": "release-it",
    "release:patch": "release-it patch --ci",
    "release:prerelease:dev": "release-it --ci --preRelease=dev",
    "release:prerelease:qa": "release-it --ci --preRelease=qa --no-git",
    "prepare": "husky"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.0.0",
    "@release-it/conventional-changelog": "^10.0.5",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.1.4",
    "cross-env": "^10.1.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-css-modules": "^2.12.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "release-it": "^19.2.4",
    "sass": "^1.99.0",
    "stylelint": "^17.6.0",
    "stylelint-config-css-modules": "^4.6.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^7.3.1",
    "vite-plugin-svgr": "^4.5.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "@types/react": "$@types/react",
    "@types/react-dom": "$@types/react-dom",
    "pdfjs-dist": "$pdfjs-dist",
    "react": "$react",
    "react-dom": "$react-dom",
    "typescript": "$typescript"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix --quiet"
    ],
    "*.{css,scss,sass}": [
      "stylelint --fix"
    ]
  }
}
