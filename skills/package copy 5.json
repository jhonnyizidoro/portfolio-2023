{
  "name": "fts-ctv-web-react",
  "private": true,
  "type": "module",
  "version": "2.0.0",
  "scripts": {
    "build": "react-router build",
    "build:docker": "pnpm dist && docker build -t fts-ctv-web-react .",
    "dev": "cross-env NODE_ENV=local PORT=5173 node server.js",
    "start": "node server.js",
    "start:ondemand": "PORT=80 node server.js",
    "start:docker": "docker stop fts-ctv-web-react 2>/dev/null || true && docker run -p 3000:3000 --name fts-ctv-web-react --rm fts-ctv-web-react",
    "dist": "./scripts/build_dist.sh",
    "typecheck": "react-router typegen && tsc",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:watch": "vitest --watch",
    "prepare": "if [ \"$HUSKY\" != \"0\" ]; then husky; fi",
    "lint": "eslint --fix --ext .ts,.tsx",
    "format": "prettier --write"
  },
  "dependencies": {
    "@datadog/browser-rum": "^6.12.3",
    "@datadog/browser-rum-react": "^6.12.3",
    "@firebolt-js/sdk": "^1.7.0",
    "@foxcorp/foxkit-profile-js": "^7.2.1",
    "@noriginmedia/norigin-spatial-navigation": "^2.3.0",
    "@react-router/express": "^7.6.2",
    "@react-router/node": "^7.6.2",
    "axios": "^1.10.0",
    "compression": "^1.8.0",
    "dd-trace": "^5.56.0",
    "dotenv": "^17.0.1",
    "express": "^5.1.0",
    "firebase": "^11.9.1",
    "hls.js": "^1.6.5",
    "isbot": "^5.1.28",
    "modern-normalize": "^3.0.1",
    "morgan": "^1.10.0",
    "node-fetch": "^3.3.2",
    "qrcode": "^1.5.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-error-boundary": "^6.0.0",
    "react-router": "^7.10.1",
    "uuid": "^11.1.0",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.29.0",
    "@react-router/dev": "^7.6.2",
    "@remix-run/testing": "^2.16.8",
    "@tailwindcss/vite": "^4.1.11",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.3",
    "@types/express-serve-static-core": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.15.33",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-legacy": "^7.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/eslint-plugin": "^1.3.3",
    "@vitest/ui": "^3.2.4",
    "cross-env": "^7.0.3",
    "eslint": "^9.29.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.2.0",
    "history": "^5.3.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.1.2",
    "msw": "^2.10.2",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.13",
    "resize-observer-polyfill": "^1.5.1",
    "tailwindcss": "^4.1.11",
    "terser": "^5.43.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.0",
    "vite": "^7.2.6",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.15"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "pnpm lint",
      "pnpm format"
    ],
    "*.{json,md,css}": "pnpm format"
  },
  "packageManager": "pnpm@10.12.1+sha512.f0dda8580f0ee9481c5c79a1d927b9164f2c478e90992ad268bbb2465a736984391d6333d2c327913578b2804af33474ca554ba29c04a8b13060a717675ae3ac"
}
